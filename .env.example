# [Skill Name] credentials
# Convention: {SKILL}_{CLIENT}_{VARNAME}
# The build script auto-detects clients from this pattern and generates one ZIP per client.
#
# Place your real credentials at:
#   releases_private/skill-{name}.env   ← gitignored, never commit
#
# This file (.env.example) is public — use placeholder values only.

# CLIENT1
EXAMPLE_CLIENT1_URL=https://client1.example.com
EXAMPLE_CLIENT1_USER=your.email@client1.com
EXAMPLE_CLIENT1_APIKEY=your-api-key-here

# CLIENT2 (add more clients as needed)
# EXAMPLE_CLIENT2_URL=https://client2.example.com
# EXAMPLE_CLIENT2_USER=your.email@client2.com
# EXAMPLE_CLIENT2_APIKEY=your-api-key-here
